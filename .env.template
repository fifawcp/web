# Node environment
NODE_ENV=development

# Public canonical site URL — used for SEO metadata, canonical/hreflang URLs,
# sitemap, robots, and Open Graph tags. Defaults to https://pickems.io in code.
NEXT_PUBLIC_SITE_URL=https://pickems.io

# Internal URL of the API
BACKEND_API_URL=http://localhost:8080

# NextAuth - required
NEXTAUTH_SECRET=[cryptographically strong string, min 32 characters]
NEXTAUTH_URL=http://localhost:3000

# NextAuth session lifetime in seconds (optional - defaults to 604800 = 7 days).
# Keep in sync with JWT_REFRESH_TOKEN_EXPIRY and AUTH_SESSION_TTL on the API.
NEXTAUTH_SESSION_MAX_AGE=604800
